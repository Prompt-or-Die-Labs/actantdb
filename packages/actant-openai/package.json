{
  "name": "@actantdb/openai",
  "version": "0.0.14",
  "description": "Drop-in replacement for the openai package that records every chat.completions.create() / responses.create() call to the ActantDB ledger as a model_call event.",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    }
  },
  "dependencies": {
    "@actantdb/core": "workspace:*",
    "@actantdb/policy": "workspace:*",
    "@actantdb/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Prompt-or-Die-Labs/actantdb"
  },
  "keywords": [
    "openai",
    "gpt",
    "actantdb",
    "agent",
    "replay",
    "audit",
    "observability"
  ],
  "homepage": "https://github.com/Prompt-or-Die-Labs/actantdb#readme",
  "bugs": {
    "url": "https://github.com/Prompt-or-Die-Labs/actantdb/issues"
  }
}
