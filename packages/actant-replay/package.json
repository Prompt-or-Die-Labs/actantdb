{
  "name": "@actantdb/replay",
  "version": "0.0.4",
  "description": "Replay engine: checkpoint, run-from-event, diff, override (policy / memory / model).",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@actantdb/core": "workspace:*",
    "@actantdb/policy": "workspace:*",
    "@actantdb/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Prompt-or-Die-Labs/actantdb"
  },
  "homepage": "https://github.com/Prompt-or-Die-Labs/actantdb#readme",
  "bugs": {
    "url": "https://github.com/Prompt-or-Die-Labs/actantdb/issues"
  }
}
