        "description": "Execution status."
      },
      "tool_call_id": {
        "description": "Tool call identifier (matches the request).",
        "type": "string"
      }
    },
    "required": [
      "duration_ms",
      "result",
      "status",
      "tool_call_id"
    ],
    "title": "ToolCallCompleted",
    "type": "object"
  },
