{
  "name": "create-actantdb",
  "version": "0.0.15",
  "description": "Scaffold a new ActantDB project. `npm create actantdb@latest my-app` or `npx create-actantdb my-app --template coding-agent`.",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "create-actantdb": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./templates": {
      "import": "./dist/templates.js",
      "types": "./dist/templates.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "prompts": "^2.4.2",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Prompt-or-Die-Labs/actantdb"
  },
  "keywords": [
    "actantdb",
    "scaffold",
    "create",
    "agent",
    "template"
  ],
  "homepage": "https://github.com/Prompt-or-Die-Labs/actantdb#readme",
  "bugs": {
    "url": "https://github.com/Prompt-or-Die-Labs/actantdb/issues"
  }
}
