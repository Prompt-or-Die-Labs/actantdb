[0,"o","\u001b[2m# actant-demo-test-cleanup — see wedge/killer-demo.md\u001b[0m\r\n"]
[1.5,"o","\u001b[2m# 1. record one agent run through the wrapper\u001b[0m\r\n"]
[3.5,"o","$ \u001b[36mnode wedge/demo/demo.mjs\u001b[0m\r\n"]
[5.5,"o","\u001b[2m[demo] using store: wedge/demo/.actantdb\u001b[0m\r\n"]
[6.5,"o","\u001b[34m[run]\u001b[0m      agent_run_started\r\n"]
[7.2,"o","\u001b[34m[run]\u001b[0m      user_message_received  \"Clean up the test artifacts.\"\r\n"]
[8.1,"o","\u001b[34m[run]\u001b[0m      context_build  3 included, 0 blocked\r\n"]
[8.5,"o","             \u001b[2m↳ memory: \"build artifacts live under /build and /dist\"\u001b[0m \u001b[33m⚠ stale\u001b[0m\r\n"]
[9.7,"o","\u001b[35m[planner]\u001b[0m  model_call  planner: shell.run \"rm -rf build dist\"\r\n"]
[11.1,"o","\u001b[34m[tool]\u001b[0m     tool_call_requested  shell.run {\"command\":\"rm -rf build dist\"}\r\n"]
[12.7,"o","\u001b[33m[guard]\u001b[0m    guard_verdict  \u001b[1mrequire_approval\u001b[0m — constrain hint: drop dist\r\n"]
[14.7,"o","\u001b[33m[approval]\u001b[0m approve_constrained → \"rm -rf build\"\r\n"]
[15.7,"o","\u001b[34m[tool]\u001b[0m     tool_call_started  shell.run {\"command\":\"rm -rf build\"}\r\n"]
[17.1,"o","\u001b[32m[ok]\u001b[0m       effect_completed  exit=0, \"Removed 14 files.\"\r\n"]
[17.9,"o","\u001b[34m[run]\u001b[0m      agent_run_finished\r\n"]
[18.9,"o","\u001b[32m✅ Recorded killer-demo run for project=demo-test-cleanup\u001b[0m\r\n"]
[19.5,"o","   Tool actually executed with: \u001b[1m{\"command\":\"rm -rf build\"}\u001b[0m\r\n\r\n"]
[21.5,"o","\u001b[2m# 2. open Studio in another terminal\u001b[0m\r\n"]
[23,"o","$ \u001b[36mACTANTDB_STORE_DIR=./wedge/demo/.actantdb \\\u001b[0m\r\n"]
[23.4,"o","  \u001b[36mnpx actantdb studio --project demo-test-cleanup\u001b[0m\r\n"]
[24.6,"o","\u001b[2mActant Studio: http://127.0.0.1:4555\u001b[0m\r\n"]
[25,"o","Studio listening on http://127.0.0.1:4555\r\n"]
[25.4,"o","Press Ctrl-C to stop.\r\n\r\n"]
[28.4,"o","\u001b[2m# 3. in the browser: click model_call → \"Replay from here\" → Run replay\u001b[0m\r\n"]
[31.4,"o","\u001b[2m# Studio renders side-by-side diff (also in wedge/demo/hero.svg):\u001b[0m\r\n"]
[32.4,"o","\r\n"]
[32.8,"o","  \u001b[2mevent              original (recorded)            replay (under overrides)\u001b[0m\r\n"]
[33,"o","  \u001b[2m─────────────────────────────────────────────────────────────────────\u001b[0m\r\n"]
[33.7,"o","  context_build      3 included, 0 blocked          \u001b[33m2 included, 1 blocked\u001b[0m\r\n"]
[34.4,"o","  model_call         \u001b[31m\"rm -rf build dist\"\u001b[0m            \u001b[32m\"rm -rf build\"\u001b[0m\r\n"]
[35.1,"o","  guard_verdict      \u001b[33mrequire_approval (constrain)\u001b[0m   \u001b[32mallow\u001b[0m\r\n"]
[35.8,"o","  tool_call          shell.run \"rm -rf build\"       shell.run \"rm -rf build\"\r\n"]
[36.5,"o","  effect_completed   exit=0                         exit=0  (recorded reuse)\r\n"]
[38,"o","\r\n"]
[38.9,"o","\u001b[34m▌\u001b[0m Without \u001b[1mmem_42_dist\u001b[0m, the planner would have proposed the safe command directly.\r\n"]
[40.3,"o","\u001b[34m▌\u001b[0m The memory caused the risky proposal; Guard caught it; replay proves the causal link.\r\n"]
[42.3,"o","\r\n"]
[43.3,"o","$ \r\n"]
