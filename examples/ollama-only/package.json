{
  "name": "actant-demo-ollama-only",
  "version": "0.0.1",
  "private": true,
  "description": "Local-model-only ActantDB demo using Ollama and a cloud-model block policy.",
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "demo": "node ./demo.mjs",
    "demo:mock": "ACTANTDB_OLLAMA_MOCK=1 node ./demo.mjs",
    "studio": "actantdb studio --project demo-ollama-only --store-dir ./.actantdb"
  },
  "dependencies": {
    "@actantdb/core": "workspace:*",
    "@actantdb/mastra": "workspace:*",
    "@actantdb/policy": "workspace:*",
    "@actantdb/studio": "workspace:*"
  },
  "engines": {
    "node": ">=22.5"
  }
}
