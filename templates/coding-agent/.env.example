# Optional overrides for the coding-agent template.
# Copy to `.env` and edit as needed.

# Where the embedded ledger writes its files.
# ACTANTDB_STORE_DIR=./.actantdb

# Port the optional actantdb-server would bind to (embedded mode ignores this).
# ACTANTDB_PORT={{port}}

# Port Studio binds to when run via `pnpm studio`.
# ACTANTDB_STUDIO_PORT={{studio_port}}

# Model provider keys — left blank because this template ships with a stub planner.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
