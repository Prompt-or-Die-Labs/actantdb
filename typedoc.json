{
  "$schema": "https://typedoc.org/schema.json",
  "entryPointStrategy": "expand",
  "entryPoints": ["packages/*/src/index.ts"],
  "out": "docs/api-typescript",
  "exclude": [
    "**/*.test.ts",
    "**/node_modules/**",
    "**/dist/**",
    "**/generated/**"
  ],
  "name": "ActantDB TypeScript API",
  "readme": "none",
  "skipErrorChecking": true,
  "excludePrivate": true,
  "excludeInternal": true,
  "hideGenerator": true,
  "githubPages": false
}
